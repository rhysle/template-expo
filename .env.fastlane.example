# Fastlane credentials template
# Copy this file to .env.fastlane.local (gitignored) and fill in the values.
# Fastfile auto-loads .env.fastlane.local at startup.

# --- iOS: App Store Connect API key ---
# Create in App Store Connect → Users and Access → Keys (App Manager role).
# Download the .p8 file ONCE; drop it under fastlane/.private/.
APP_STORE_CONNECT_API_KEY_KEY_ID=
APP_STORE_CONNECT_API_KEY_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=./fastlane/.private/AuthKey_XXXXXXXX.p8

# Optional — only needed if you fall back to Apple ID auth instead of the API key
# APPLE_ID=
# APPLE_TEAM_ID=
# ITC_TEAM_ID=

# --- Android: Google Play service account JSON ---
# Create in Google Cloud Console → IAM → Service accounts, then invite into
# Play Console → Users and permissions with metadata/listing permissions.
GOOGLE_PLAY_JSON_KEY_PATH=./fastlane/.private/play-service-account.json
