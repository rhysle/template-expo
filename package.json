{
  "name": "template-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android-device": "expo run:android --device",
    "ios-device": "expo run:ios --device",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "eas-build": "eas build --platform all",
    "eas-build:ios": "eas build --platform ios",
    "eas-build:android": "eas build --platform android",
    "eas-build-run:ios": "eas build:run -p ios",
    "eas-build-run:android": "eas build:run -p android",
    "lint": "expo lint",
    "check:type": "tsc --noEmit",
    "check:compiler": "npx react-compiler-healthcheck@latest",
    "check": "npm run lint && npm run check:type",
    "doctor": "npx expo-doctor",
    "align-deps": "npx expo install --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@expo/ui": "~56.0.14",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "date-fns": "^4.1.0",
    "expo": "~56.0.5",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.12",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.7",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "i18next": "^25.8.14",
    "immer": "^11.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.5.5",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3"
  },
  "private": true
}
