{
  "name": "template-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "JAVA_HOME=$(/usr/libexec/java_home -v 17) expo run:android",
    "android:device": "JAVA_HOME=$(/usr/libexec/java_home -v 17) expo run:android --device",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:ios:clean": "expo prebuild --clean --platform ios",
    "prebuild:android:clean": "expo prebuild --clean --platform android",
    "eas-build": "eas build --platform all --profile production",
    "eas-build:local": "npm run eas-build:ios:local && npm run eas-build:android:local",
    "eas-build:ios": "eas build --platform ios --profile production",
    "eas-build:ios:submit": "eas build --platform ios --profile production --auto-submit",
    "eas-build:ios:local": "set -a && . ./.env.local && set +a && eas build --platform ios --profile production --local",
    "eas-build:android": "eas build --platform android --profile production",
    "eas-build:android:submit": "eas build --platform android --profile production --auto-submit",
    "eas-build:android:local": "set -a && . ./.env.local && set +a && JAVA_HOME=$(/usr/libexec/java_home -v 17) eas build --platform android --profile production --local",
    "eas-build-run:ios": "eas build:run -p ios",
    "eas-build-run:android": "eas build:run -p android",
    "eas-submit:ios": "eas submit --platform ios",
    "eas-submit:android": "eas submit --platform android",
    "eas-update:android": "eas update --channel production --environment production --platform android",
    "eas-update:ios": "eas update --channel production --environment production --platform ios",
    "eas-update": "npm run eas-update:android && npm run eas-update:ios",
    "lint": "expo lint",
    "check:type": "tsc --noEmit",
    "check:compiler": "npx react-compiler-healthcheck@latest",
    "check:i18n": "npx tsx scripts/check-i18n.ts",
    "check:i18n:fix": "npx tsx scripts/check-i18n.ts --remove-unused",
    "check": "npm run lint && npm run check:type",
    "release:version": "npx tsx scripts/bump-version.ts",
    "release:patch": "npm run release:version -- patch",
    "release:minor": "npm run release:version -- minor",
    "release:major": "npm run release:version -- major",
    "release:verify-config": "APP_VARIANT=production npx expo config --type public",
    "setup:expo": "npx tsx scripts/setup-expo.ts",
    "setup:i18n": "npx tsx scripts/setup-i18n.ts",
    "setup:ads": "npx tsx scripts/setup-ads.ts",
    "setup:font": "npx tsx scripts/setup-font.ts",
    "fastlane:ios:init": "fastlane ios init_metadata",
    "fastlane:ios:metadata": "fastlane ios metadata",
    "fastlane:ios:metadata:globals": "fastlane ios metadata globals:true",
    "fastlane:ios:metadata:test": "fastlane ios metadata locales:\"en-US,vi\"",
    "fastlane:android:init": "fastlane android init_metadata",
    "fastlane:android:metadata": "fastlane android metadata",
    "fastlane:android:metadata:test": "fastlane android metadata locales:\"en-US,vi\"",
    "fastlane:android:metadata:validate": "fastlane android metadata validate_only:true",
    "fastlane:android:changelog": "fastlane android changelog track:internal",
    "fastlane:android:changelog:test": "fastlane android changelog locales:\"en-US,es-ES\" track:internal validate_only:true",
    "doctor": "npx expo-doctor",
    "align-deps": "npx expo install --fix",
    "format": "prettier ./src --write --log-level error && eslint ./src --fix --quiet"
  },
  "dependencies": {
    "@expo/ui": "~57.0.4",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.7.0",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "date-fns": "^4.3.0",
    "expo": "^57.0.0",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-network": "~57.0.0",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-tracking-transparency": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "i18next": "^26.3.0",
    "immer": "^11.1.8",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-google-mobile-ads": "16.3.4",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-purchases": "^10.1.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@dev-plugins/react-query": "^0.4.0",
    "@expo-google-fonts/dev": "^0.4.72",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "zod-validation-error": "^4.0.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": []
      },
      "android": {
        "exclude": []
      }
    }
  }
}
