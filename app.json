{
  "expo": {
    "name": "Template Expo",
    "slug": "template-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.rhysle.expo",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "bundleIdentifier": "com.rhysle.expo",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "allowBackup": false,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rhysle.expo",
      "googleServicesFile": "./google-services.json",
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#208AEF"
        }
      ],
      [
        "expo-localization",
        {
          "supportsRTL": true,
          "supportedLocales": [
            "ar",
            "bn",
            "cs",
            "da",
            "de",
            "el",
            "en",
            "es",
            "fi",
            "fr",
            "he",
            "hi",
            "hr",
            "hu",
            "id",
            "it",
            "ja",
            "ko",
            "ms",
            "nb",
            "nl",
            "pl",
            "pt",
            "pt-BR",
            "ro",
            "ru",
            "sv",
            "th",
            "tr",
            "uk",
            "vi",
            "zh-Hans",
            "zh-Hant"
          ]
        }
      ],
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "template-expo",
          "organization": "rhysle"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
          },
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAnalytics"]
          }
        }
      ],
      "expo-updates",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4662625232077043~8614004722",
          "iosAppId": "ca-app-pub-4662625232077043~6949204305",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "@react-native-firebase/app",
      "./plugins/withRNFirebaseStaticFramework.js",
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": false,
          "iosMicrophonePermission": "Water Eject uses the microphone only while the dB Meter is running to estimate nearby sound levels. Audio is processed on your device and is never saved.",
          "androidPermissions": ["android.permission.RECORD_AUDIO"],
          "androidForegroundService": false,
          "androidFSTypes": []
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6399fac2-52c4-4cde-81f1-14c928819922"
      }
    },
    "owner": "rhysle",
    "updates": {
      "url": "https://u.expo.dev/6399fac2-52c4-4cde-81f1-14c928819922"
    }
  }
}
