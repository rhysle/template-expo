require "fileutils"
require "json"

default_platform(:ios)

# Load credentials from .env.fastlane.local if present.
# This is gitignored — copy .env.fastlane to .env.fastlane.local and fill in values.
env_file = File.expand_path("../.env.fastlane.local", __dir__)
if File.exist?(env_file)
  File.foreach(env_file) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    key, value = line.split("=", 2)
    ENV[key] ||= value if key && value
  end
end

# They are written to every iOS locale by `deliver` so we never duplicate per-locale.
# deliver expects `type: Hash` for these localized fields; the magic key
# "default" means "apply this value to every locale".
SHARED_IOS_URLS = {
  support_url: { "default" => "https://rhysle.com/contact" },
  marketing_url: { "default" => "https://rhysle.com" },
  privacy_url: { "default" => "https://rhysle.com/privacy" },
}.freeze

# Parse a comma-separated `locales:"en-US,vi"` CLI parameter into an array.
# Returns nil when the parameter is absent, meaning "upload all locales".
def parse_locales(options)
  raw = options[:locales]
  return nil if raw.nil? || raw.strip.empty?
  raw.split(",").map(&:strip).reject(&:empty?)
end

PROJECT_ROOT = File.expand_path("..", __dir__).freeze

# Resolve a path that may be relative to the project root (where the user runs
# `npm run`). Fastlane changes cwd at lane time, so any relative path provided
# via env vars must be re-anchored to PROJECT_ROOT explicitly.
def resolve_project_path(path)
  File.expand_path(path, PROJECT_ROOT)
end

# Build an ASC API key hash from the three env vars used by the `metadata` lane,
# write it as the JSON file format that `deliver init` (a CLI subcommand) expects,
# and return the absolute path. The temp file lives under `fastlane/.tmp/` (gitignored).
def write_asc_api_key_json
  key_filepath = resolve_project_path(ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"))
  unless File.exist?(key_filepath)
    UI.user_error!("App Store Connect .p8 key not found at: #{key_filepath}")
  end

  tmp_dir = File.join(PROJECT_ROOT, "fastlane/.tmp")
  FileUtils.mkdir_p(tmp_dir)
  path = File.join(tmp_dir, "asc_api_key.json")
  payload = {
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key: File.read(key_filepath),
    in_house: false,
  }
  File.write(path, JSON.dump(payload))
  path
end

# Mirror a subset of locale folders from `src_root` into `dst_root` so the
# upload tool only sees the locales we want. Returns the dst path.
#
# Why this helper exists at all:
# - `supply` (Android) has no language filter — it uploads every folder in `metadata_path`.
# - `deliver` (iOS) has a `languages:` option, but it's ADDITIVE: it ensures the listed
#   locales exist in ASC, then appends every folder found in `metadata_path` on top.
#   So neither tool natively supports "upload only these N locales".
#
# `preserve:` is for non-locale entries that should be copied alongside the
# locale folders (e.g. iOS globals like `review_information/`). Top-level files
# in `src_root` are always preserved.
def build_filtered_locale_tree(src_root, dst_root, locales, preserve: [])
  FileUtils.rm_rf(dst_root)
  FileUtils.mkdir_p(dst_root)

  locales.each do |locale|
    src = File.join(src_root, locale)
    unless Dir.exist?(src)
      UI.user_error!("Folder not found for locale '#{locale}' in #{src_root}")
    end
    FileUtils.cp_r(src, dst_root)
  end

  Dir.children(src_root).each do |child|
    src = File.join(src_root, child)
    if File.file?(src)
      FileUtils.cp(src, dst_root)
    elsif File.directory?(src) && preserve.include?(child)
      FileUtils.cp_r(src, dst_root)
    end
  end

  dst_root
end

platform :ios do
  desc "Pull live ASC listing into fastlane/ios/metadata + screenshots (one-shot bootstrap)."
  lane :init_metadata do
    key_path = write_asc_api_key_json
    metadata_path = File.join(PROJECT_ROOT, "fastlane/ios/metadata")
    screenshots_path = File.join(PROJECT_ROOT, "fastlane/ios/screenshots")
    deliverfile_path = File.join(PROJECT_ROOT, "fastlane/Deliverfile")
    begin
      Dir.chdir(PROJECT_ROOT) do
        sh("fastlane deliver init --api_key_path '#{key_path}' --metadata_path '#{metadata_path}' --screenshots_path '#{screenshots_path}'")
      end
    ensure
      File.delete(key_path) if File.exist?(key_path)
      # `deliver init` always generates a Deliverfile. We don't use it — every
      # option is set inline in the `metadata` lane below — so remove it to
      # prevent silent config drift.
      if File.exist?(deliverfile_path)
        File.delete(deliverfile_path)
        UI.message("Removed generated Deliverfile (all config lives in Fastfile).")
      end
    end
  end

  desc "Upload iOS metadata + screenshots. Pass `locales:\"en-US,vi\"` to limit."
  lane :metadata do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"),
      in_house: false,
    )

    metadata_root = File.join(PROJECT_ROOT, "fastlane/ios/metadata")
    screenshots_root = File.join(PROJECT_ROOT, "fastlane/ios/screenshots")
    locales = parse_locales(options)
    globals_only = options[:globals] == true || options[:globals] == "true"

    if globals_only
      UI.message("Globals-only upload: skipping all locale folders and screenshots.")
      metadata_path = build_filtered_locale_tree(
        metadata_root,
        File.join(PROJECT_ROOT, "fastlane/.tmp/ios-metadata"),
        [],
        preserve: ["review_information"],
      )
      screenshots_path = nil
    elsif locales
      UI.message("Restricting upload to locales: #{locales.join(', ')}")
      metadata_path = build_filtered_locale_tree(
        metadata_root,
        File.join(PROJECT_ROOT, "fastlane/.tmp/ios-metadata"),
        locales,
        preserve: ["review_information"],
      )
      screenshots_path = build_filtered_locale_tree(
        screenshots_root,
        File.join(PROJECT_ROOT, "fastlane/.tmp/ios-screenshots"),
        locales,
      )
    else
      metadata_path = metadata_root
      screenshots_path = screenshots_root
    end

    deliver_options = {
      api_key: api_key,
      metadata_path: metadata_path,
      skip_binary_upload: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      app_rating_config_path: File.join(PROJECT_ROOT, "fastlane/ios/metadata/app_rating_config.json"),
      **SHARED_IOS_URLS,
    }

    if globals_only
      deliver_options[:skip_screenshots] = true
      deliver_options[:skip_metadata] = false
    else
      deliver_options[:screenshots_path] = screenshots_path
      deliver_options[:overwrite_screenshots] = true
    end

    deliver(**deliver_options)
  end
end

platform :android do
  desc "Pull live Play listing into fastlane/android/metadata (one-shot bootstrap)."
  lane :init_metadata do
    json_key = resolve_project_path(ENV.fetch("GOOGLE_PLAY_JSON_KEY_PATH"))
    unless File.exist?(json_key)
      UI.user_error!("Google Play service account JSON not found at: #{json_key}")
    end
    metadata_path = File.join(PROJECT_ROOT, "fastlane/android/metadata")
    # supply init refuses to download when the directory already exists — remove it first.
    FileUtils.rm_rf(metadata_path)
    Dir.chdir(PROJECT_ROOT) do
      sh("fastlane supply init --metadata_path '#{metadata_path}' --json_key '#{json_key}' --package_name com.rhysle.currencyconverter")
    end
  end

  desc "Upload Android metadata + screenshots. Pass `locales:\"en-US,vi\"` to limit."
  lane :metadata do |options|
    metadata_root = File.join(PROJECT_ROOT, "fastlane/android/metadata")
    locales = parse_locales(options)

    metadata_path =
      if locales
        UI.message("Restricting upload to locales: #{locales.join(', ')}")
        build_filtered_locale_tree(
          metadata_root,
          File.join(PROJECT_ROOT, "fastlane/.tmp/android-metadata"),
          locales,
        )
      else
        metadata_root
      end

    supply(
      track: "production",
      metadata_path: metadata_path,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true, # no APK/AAB uploaded → no version_code → changelogs can't be uploaded
      skip_upload_images: false,
      skip_upload_screenshots: false,
      validate_only: options[:validate_only] == true || options[:validate_only] == "true",
    )
  end

  desc "Upload Android default changelogs only. Resolves the latest versionCode on the selected track."
  lane :changelog do |options|
    metadata_root = File.join(PROJECT_ROOT, "fastlane/android/metadata")
    locales = parse_locales(options)
    track = options[:track] || "internal"

    version_code = options[:version_code] || google_play_track_version_codes(track: track).max
    unless version_code.to_s.match?(/\A\d+\z/)
      UI.user_error!(
        "No version codes found on the '#{track}' track. " \
        "Upload a release first or pass version_code:<code> to target a specific release.",
      )
    end

    version_code = version_code.to_i

    metadata_path =
      if locales
        UI.message("Restricting changelog upload to locales: #{locales.join(', ')}")
        build_filtered_locale_tree(
          metadata_root,
          File.join(PROJECT_ROOT, "fastlane/.tmp/android-changelog"),
          locales,
        )
      else
        metadata_root
      end

    UI.message("Uploading Android changelogs for versionCode #{version_code} to #{track} track.")

    supply(
      track: track,
      metadata_path: metadata_path,
      version_code: version_code,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: options[:validate_only] == true || options[:validate_only] == "true",
    )
  end
end
